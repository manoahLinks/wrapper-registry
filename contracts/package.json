{
  "name": "confidential-wrapper-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Factory + community registry for deploying ERC-7984 confidential wrappers from the UI.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat deploy --network sepolia --tags factory",
    "deploy:mainnet": "hardhat deploy --network mainnet --tags factory",
    "verify:sepolia": "hardhat etherscan-verify --network sepolia",
    "verify:mainnet": "hardhat etherscan-verify --network mainnet"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "0.4.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.17.6",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.16",
    "hardhat-deploy": "^0.12.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@fhevm/solidity": "0.11.1",
    "@openzeppelin/confidential-contracts": "0.4.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "encrypted-types": "^0.0.4"
  }
}
