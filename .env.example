# ---------------------------------------------------------------------------
# Confidential Wrapper Registry — environment variables
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Sepolia RPC endpoint (Alchemy / Infura / your own node).
# Used for all Sepolia on-chain reads and writes. Falls back to a public RPC if
# unset, but a dedicated key is strongly recommended to avoid rate limits.
VITE_SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# Ethereum mainnet RPC endpoint. Used for mainnet reads/writes. Falls back to a
# public RPC if unset; a dedicated key is strongly recommended (FHEVM reads are
# heavier than usual). Leave unset to stay testnet-focused.
VITE_MAINNET_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# WalletConnect / Reown project ID (https://cloud.reown.com).
# Required by RainbowKit for WalletConnect-based wallets.
VITE_WALLETCONNECT_PROJECT_ID="YOUR_WALLETCONNECT_PROJECT_ID"

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY — never prefixed with VITE_, never exposed to the browser.
# Consumed by the Vercel serverless function at api/relayer/[...path].ts, which
# proxies mainnet FHEVM relayer calls and injects this key as the x-api-key
# header. Required ONLY for mainnet; Sepolia's relayer is keyless.
# Get a key: https://docs.zama.org (Relayer SDK → mainnet API key).
# Set it in Vercel: Project Settings → Environment Variables.
# ---------------------------------------------------------------------------
RELAYER_API_KEY="YOUR_ZAMA_MAINNET_RELAYER_API_KEY"

