# ---------------------------------------------------------------------------
# Confidential Wrapper Registry — environment variables
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Sepolia RPC endpoint (Alchemy / Infura / your own node).
# Used for all on-chain reads and writes. Falls back to a public RPC if unset,
# but a dedicated key is strongly recommended to avoid rate limits in the demo.
VITE_SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# WalletConnect / Reown project ID (https://cloud.reown.com).
# Required by RainbowKit for WalletConnect-based wallets.
VITE_WALLETCONNECT_PROJECT_ID="YOUR_WALLETCONNECT_PROJECT_ID"
